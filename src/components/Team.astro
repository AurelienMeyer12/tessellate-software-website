---
import { teamMembers } from '../data/team';
import TeamMember from './TeamMember.astro';
---

<section class="section section--alt" id="team" aria-labelledby="team-title">
  <div class="wrap">
    <header class="sec-head">
      <div class="sec-head__eyebrow"><span class="sec-head__num">03</span> The Team</div>
      <div>
        <h2 id="team-title" class="sec-head__title">Operators, investors, builders.</h2>
        <p class="sec-head__lede">A small partnership of people who have built, sold, scaled, and stewarded software businesses — and who show up for founders when it counts.</p>
      </div>
    </header>

    <div class="team-grid" role="list">
      {teamMembers.map((member) => (
        <TeamMember
          name={member.name}
          role={member.role}
          image={member.image}
          linkedin={member.linkedin}
          bio={member.bio}
        />
      ))}
    </div>
  </div>
</section>
