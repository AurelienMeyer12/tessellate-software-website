---
import { allianceData } from '../data/alliance';
---

<section id="alliance" class="block block--cream alliance">
  <div class="u-center alliance__wrap">
    <header class="alliance__head">
      <h2 class="alliance__title">{allianceData.title}</h2>
      <p class="alliance__sub">{allianceData.subtitle}</p>
    </header>

    <div class="alliance__grid" role="list">
      {allianceData.cards.map((card) => (
        <article class="alliance__card" role="listitem">
          <h3>{card.title}</h3>
          <p set:html={card.description} />
        </article>
      ))}
    </div>

    <div class="alliance__logos" aria-label="Representative client logos">
      {allianceData.logos.map((logo) => {
        // Extract company name from logo filename
        const filename = logo.split('/').pop() || '';
        const companyName = filename
          .replace(/-logo\.(png|svg|webp|jpg|jpeg)$/i, '')
          .replace(/[_-]/g, ' ')
          .replace(/\b\w/g, (char: string) => char.toUpperCase());
        return <img class="logo--color" src={logo} alt={`${companyName} logo`} />;
      })}
    </div>

    <p class="alliance__note">{allianceData.note}</p>
  </div>
</section>

