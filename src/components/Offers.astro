---
import { offers } from '../data/offers';

const romanNumerals = ['i', 'ii', 'iii', 'iv', 'v', 'vi'];
---

<section class="section section--alt" id="offers" aria-labelledby="offers-title">
  <div class="wrap">
    <header class="sec-head">
      <div class="sec-head__eyebrow"><span class="sec-head__num">01</span> What we bring</div>
      <div>
        <h2 id="offers-title" class="sec-head__title">Operator–investors focused on durable growth.</h2>
        <p class="sec-head__lede">A small team with deep benches in engineering, go-to-market, and capital strategy — at the ready when founders need them.</p>
      </div>
    </header>

    <div class="offers-grid" role="list">
      {offers.map((offer, index) => (
        <article class="offer" role="listitem">
          <span class="offer__num">{romanNumerals[index]}</span>
          <h3 class="offer__title">{offer.title}</h3>
          <p class="offer__body">{offer.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
